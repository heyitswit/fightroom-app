{
  "name": "@fightroom/share-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Serveur de partage de codes d'accès entre amis Fight Room (Lacis).",
  "scripts": {
    "dev": "tsx watch server.ts",
    "start": "tsx server.ts",
    "build": "lacis build",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "lacis": "^0.5.0",
    "postgres": "^3.4.9",
    "tsx": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.31.10",
    "typescript": "~5.9.2"
  }
}
