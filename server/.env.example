# Postgres connection string (required). Works with any Postgres provider
# (Aiven, Neon, Supabase, Vercel Postgres…). Keep ?sslmode=require for managed DBs.
DATABASE_URL="postgres://user:password@host:5432/dbname?sslmode=require"

# Port to listen on (Node/Bun). Ignored on serverless (Vercel/Netlify).
PORT=3000

# Set to "production" to disable dev mode / verbose errors.
# NODE_ENV=production
